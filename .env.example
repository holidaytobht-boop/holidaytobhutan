# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
DB_NAME=holidaytobhutan

# Admin bootstrap credentials (required — hashed on first boot; change via Admin → Account after login)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeThisPassword1!

# Auth — required (generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))")
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Required in production — comma-separated site URLs for CSRF protection
CLIENT_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=
PORT=3000

# Set to true when deployed behind a reverse proxy (nginx, Vercel, etc.)
TRUST_PROXY=false

# Contact form + Plan My Trip email notifications
# Option 1 (recommended): free key at https://web3forms.com
WEB3FORMS_ACCESS_KEY=

# Option 2: Gmail SMTP (App Password at https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_EMAIL_TO=holidaytobht@gmail.com

# Google Places API — live reviews on the homepage (optional)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
GOOGLE_REVIEWS_CACHE_TTL_MS=3600000
